# Template — DO NOT commit a populated copy.
# The real Secret is rendered by scripts/k8s-up.sh from GHCR_USERNAME +
# GHCR_PAT in .env.
#
# ArgoCD must be told the URL is an OCI registry (enableOCI: "true").
# The url has no scheme — ArgoCD prepends oci:// internally.

apiVersion: v1
kind: Secret
metadata:
  name: helm-charts-ghcr
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  type: helm
  name: ghcr-<your-github-user>-charts
  url: ghcr.io/<your-github-user>/charts
  enableOCI: "true"
  username: REPLACE_ME_VIA_ENV
  password: REPLACE_ME_VIA_ENV
