# ─── service-platform-template — environment configuration ──────────
# Copy this to .env and fill in the values. ./scripts/init-env.sh will
# auto-generate any var marked with 'auto-generate' below.

# ─── Domain / hostnames ─────────────────────────────────────────────
# All workload + ArgoCD URLs use this domain. Default 'svc.localhost'
# works locally with /etc/hosts. For real public access, set to your
# actual domain (e.g., svc.example.com) AND configure cert-manager
# for ACME DNS-01 (see docs/cert-manager.md).
DOMAIN=svc.localhost

# ─── Application secrets ────────────────────────────────────────────
# auto-generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace_me

# auto-generate: openssl rand -hex 48
VAULTWARDEN_ADMIN_TOKEN=replace_me

# ─── Real certificates (opt-in) ─────────────────────────────────────
# Only relevant if you switch from the default self-signed issuer to
# Let's Encrypt. See docs/cert-manager.md for the full setup. These
# vars are unused in the default path.
# ACME_EMAIL=you@example.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_HOSTED_ZONE_ID=

# ─── Private chart mirror (opt-in) ──────────────────────────────────
# Only relevant if you set up a GHCR chart mirror. See docs/ghcr-mirror.md.
# GITHUB_USER=your-github-user
# GHCR_PAT=
