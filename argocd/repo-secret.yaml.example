# Template — DO NOT commit a populated copy.
# The real Secret is rendered by scripts/k8s-up.sh from values in .env
# and applied directly to the cluster. The rendered file (if it ever
# lands on disk during debugging) is gitignored at argocd/repo-secret.yaml.
#
# ArgoCD discovers Repository Secrets by the label below. The data keys
# are dictated by ArgoCD: type=git, url, sshPrivateKey.
#
# See: https://argo-cd.readthedocs.io/en/stable/operator-manual/declarative-setup/#repositories

apiVersion: v1
kind: Secret
metadata:
  name: repo-service-platform-template
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  type: git
  url: git@github.com:<your-github-user>/service-platform-template.git
  sshPrivateKey: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    REPLACE_ME_VIA_ENV
    -----END OPENSSH PRIVATE KEY-----
